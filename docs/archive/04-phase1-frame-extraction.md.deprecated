# 04 — Phase 1: 4K Frame Extraction (Zero Shutter Lag)

## Concept

แทนที่จะ "ถ่ายภาพ" ใหม่เมื่อนักวิ่งเข้ามา — เราดึง frame ที่กำลังถ่ายวิดีโออยู่แล้วออกมาทันที

```
Video stream is ALWAYS running → frame is already captured → just copy it out
```

**ไม่มีการรอ** — ไม่มี AE lock, ไม่มี AF re-calculation, ไม่มี mechanical lag ใดๆ

---

## CameraX Use-Case Setup

### Concurrent Use-Cases ที่ต้องใช้

```
CameraX ProcessCameraProvider
├── Preview          ← แสดงบนหน้าจอ (optional ถ้าใช้ tripod)
├── VideoCapture     ← บันทึก 4K video ต่อเนื่อง
└── ImageAnalysis    ← รับ YUV frames สำหรับ Face Detection (downscaled)
```

> ⚠️ **ข้อจำกัด:** อุปกรณ์บางรุ่นไม่รองรับ VideoCapture + ImageAnalysis พร้อมกัน  
> ตรวจสอบด้วย `CameraX ConcurrentCamera` API หรือ Camera2 `isSessionConfigurationSupported()`

---

## `CameraXPipeline.kt` (androidMain)

```kotlin
package com.autobots.camera.pipeline

import android.content.Context
import androidx.camera.core.*
import androidx.camera.lifecycle.ProcessCameraProvider
import androidx.camera.video.*
import androidx.core.content.ContextCompat
import androidx.lifecycle.LifecycleOwner
import com.autobots.camera.capture.AdaptiveCaptureQueue
import com.autobots.camera.capture.FrameExtractStrategy
import com.autobots.camera.detection.TFLiteFaceDetector
import com.autobots.camera.detection.ProximityCalculator
import com.autobots.camera.thermal.AndroidThermalMonitor
import com.autobots.camera.thermal.ThermalStatus
import java.util.concurrent.Executors

class CameraXPipeline(
    private val context: Context,
    private val lifecycleOwner: LifecycleOwner,
    private val outputDir: java.io.File
) {
    private val analysisExecutor = Executors.newSingleThreadExecutor()
    private val thermalMonitor   = AndroidThermalMonitor(context)
    private val captureQueue     = AdaptiveCaptureQueue(outputDir)
    private val faceDetector     = TFLiteFaceDetector(context)

    // Strategy pattern — swap here for Phase 2
    private val captureStrategy  = FrameExtractStrategy(captureQueue)

    fun start(previewSurface: androidx.camera.core.SurfaceRequest? = null) {
        val cameraProviderFuture = ProcessCameraProvider.getInstance(context)

        cameraProviderFuture.addListener({
            val cameraProvider = cameraProviderFuture.get()

            // ── Preview (optional) ────────────────────────────────────
            val preview = Preview.Builder()
                .setTargetResolution(android.util.Size(1920, 1080))  // preview can be 1080p
                .build()

            // ── VideoCapture 4K ───────────────────────────────────────
            val qualitySelector = QualitySelector.from(
                Quality.UHD,                           // 4K (3840×2160)
                FallbackStrategy.higherQualityOrLowerThan(Quality.FHD)
            )
            val videoRecorder = Recorder.Builder()
                .setQualitySelector(qualitySelector)
                .setExecutor(analysisExecutor)
                .build()
            val videoCapture = VideoCapture.withOutput(videoRecorder)

            // ── ImageAnalysis (for Face Detection only) ───────────────
            val imageAnalysis = ImageAnalysis.Builder()
                .setTargetResolution(android.util.Size(640, 360))    // downscale for AI speed
                .setBackpressureStrategy(ImageAnalysis.STRATEGY_KEEP_ONLY_LATEST)
                .setOutputImageFormat(ImageAnalysis.OUTPUT_IMAGE_FORMAT_YUV_420_888)
                .build()
                .also { analysis ->
                    analysis.setAnalyzer(analysisExecutor, FaceAnalyzer(
                        detector        = faceDetector,
                        captureStrategy = captureStrategy,
                        thermalMonitor  = thermalMonitor
                    ))
                }

            // ── Bind use-cases ────────────────────────────────────────
            val cameraSelector = CameraSelector.DEFAULT_BACK_CAMERA
            try {
                cameraProvider.unbindAll()
                cameraProvider.bindToLifecycle(
                    lifecycleOwner,
                    cameraSelector,
                    preview,
                    videoCapture,
                    imageAnalysis
                )

                // Start recording immediately
                startRecording(videoRecorder)

            } catch (e: Exception) {
                android.util.Log.e("CameraXPipeline", "Use case binding failed", e)
            }

        }, ContextCompat.getMainExecutor(context))

        thermalMonitor.start { status ->
            captureStrategy.applyThermalThrottle(status)
        }
    }

    private fun startRecording(recorder: Recorder) {
        val outputFile = java.io.File(outputDir, "session_${System.currentTimeMillis()}.mp4")
        val fileOutputOptions = FileOutputOptions.Builder(outputFile).build()

        recorder.prepareRecording(context, fileOutputOptions)
            .withAudioDisabled()          // no audio needed
            .start(analysisExecutor) { event ->
                when (event) {
                    is VideoRecordEvent.Start  -> android.util.Log.d("CameraX", "Recording started")
                    is VideoRecordEvent.Status -> { /* monitoring */ }
                    is VideoRecordEvent.Finalize -> android.util.Log.d("CameraX", "Recording done: ${event.outputResults}")
                }
            }
    }

    fun stop() {
        thermalMonitor.stop()
        captureQueue.shutdown()
        faceDetector.close()
        analysisExecutor.shutdown()
    }
}
```

