## `FaceAnalyzer.kt` (androidMain)

```kotlin
package com.autobots.camera.pipeline

import androidx.camera.core.ImageAnalysis
import androidx.camera.core.ImageProxy
import com.autobots.camera.capture.CaptureStrategy
import com.autobots.camera.capture.FrameContext
import com.autobots.camera.detection.FaceDetector
import com.autobots.camera.detection.ProximityCalculator
import com.autobots.camera.thermal.AndroidThermalMonitor
import com.autobots.camera.thermal.ThermalStatus
import kotlinx.coroutines.*

class FaceAnalyzer(
    private val detector: FaceDetector,
    private val captureStrategy: CaptureStrategy,
    private val thermalMonitor: AndroidThermalMonitor,
    private val proximityThreshold: Float = 0.40f,
    private val cooldownMs: Long = 500L             // min ms between captures
) : ImageAnalysis.Analyzer {

    private val analyzerScope  = CoroutineScope(Dispatchers.Default + SupervisorJob())
    private var lastCaptureMs  = 0L

    override fun analyze(image: ImageProxy) {
        // ImageAnalysis delivers downscaled YUV frames
        val planes = image.planes
        val yBuffer = planes[0].buffer
        val uBuffer = planes[1].buffer
        val vBuffer = planes[2].buffer

        val ySize = yBuffer.remaining()
        val uSize = uBuffer.remaining()
        val vSize = vBuffer.remaining()

        val nv21 = ByteArray(ySize + uSize + vSize)
        yBuffer.get(nv21, 0, ySize)
        vBuffer.get(nv21, ySize, vSize)          // NV21: Y + VU interleaved
        uBuffer.get(nv21, ySize + vSize, uSize)

        val width  = image.width
        val height = image.height
        val now    = System.currentTimeMillis()

        // Run detection synchronously on analyzer thread (single-threaded executor)
        val faces = detector.detect(nv21, width, height)

        if (ProximityCalculator.shouldCapture(faces, proximityThreshold)) {
            if (now - lastCaptureMs >= cooldownMs &&
                thermalMonitor.currentStatus < ThermalStatus.SEVERE) {

                lastCaptureMs = now

                // Capture on a separate coroutine; do NOT block analyze()
                analyzerScope.launch {
                    captureStrategy.capture(
                        FrameContext(
                            timestampMs  = now,
                            rotationDeg  = image.imageInfo.rotationDegrees,
                            faces        = faces
                        )
                    )
                }
            }
        }

        image.close()   // CRITICAL — must close to receive next frame
    }
}
```

