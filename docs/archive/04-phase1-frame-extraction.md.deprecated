## `FrameExtractStrategy.kt` — Phase 1 Core (androidMain)

```kotlin
package com.autobots.camera.capture

import android.graphics.Bitmap
import android.graphics.ImageFormat
import android.graphics.Rect
import android.graphics.YuvImage
import com.autobots.camera.capture.AdaptiveCaptureQueue
import java.io.ByteArrayOutputStream

/**
 * Phase 1: Extract the current frame from the VideoCapture YUV buffer.
 *
 * NOTE on architecture:
 * We share the ImageAnalysis downscaled YUV for detection,
 * but for the actual saved photo we need the FULL 4K frame.
 *
 * Two valid approaches:
 *   A) Dual ImageAnalysis surfaces (one 640p for AI, one 4K for extraction)
 *      → Requires camera2 concurrent session check
 *   B) Intercept from VideoCapture MediaCodec input buffer via ImageReader
 *      → More complex; use approach A for MVP
 *
 * This implementation uses Approach A with a secondary high-res ImageAnalysis.
 */
class FrameExtractStrategy(
    private val queue: AdaptiveCaptureQueue,
    private val jpegQuality: Int = 95
) : CaptureStrategy {

    // Injected from CameraXPipeline — holds the latest 4K ImageProxy
    @Volatile var latestFullResFrame: FullResFrameHolder? = null

    private @Volatile var thermalMultiplier: Float = 1.0f   // 1.0 = normal, >1 = slowed

    override suspend fun capture(frameContext: FrameContext): CaptureResult {
        val frame = latestFullResFrame?.acquire()
            ?: return CaptureResult.Error("No 4K frame available")

        return try {
            val jpegBytes = yuvToJpeg(
                yuvBytes      = frame.nv21Bytes,
                width         = frame.width,
                height        = frame.height,
                quality       = jpegQuality,
                rotationDeg   = frameContext.rotationDeg
            )
            queue.enqueue(CaptureJob(
                jpegBytes    = jpegBytes,
                timestampMs  = frameContext.timestampMs
            ))
            CaptureResult.Success(jpegBytes.size.toLong())
        } catch (e: Exception) {
            CaptureResult.Error(e.message ?: "Unknown error")
        } finally {
            frame.recycle()   // release ByteArray back to pool
        }
    }

    /**
     * Convert NV21 YUV byte array to JPEG using Android's built-in YuvImage.
     * For better performance, consider libyuv via JNI (see doc/06).
     */
    private fun yuvToJpeg(
        yuvBytes: ByteArray,
        width: Int,
        height: Int,
        quality: Int,
        rotationDeg: Int
    ): ByteArray {
        val yuvImage = YuvImage(yuvBytes, ImageFormat.NV21, width, height, null)
        val outputStream = ByteArrayOutputStream(yuvBytes.size / 4)  // estimate JPEG size
        yuvImage.compressToJpeg(Rect(0, 0, width, height), quality, outputStream)

        val jpegBytes = outputStream.toByteArray()

        // Handle rotation via ExifInterface after write, or rotate Bitmap here
        return if (rotationDeg != 0) rotateJpeg(jpegBytes, rotationDeg) else jpegBytes
    }

    private fun rotateJpeg(jpeg: ByteArray, degrees: Int): ByteArray {
        val bitmap = android.graphics.BitmapFactory.decodeByteArray(jpeg, 0, jpeg.size)
        val matrix = android.graphics.Matrix().apply { postRotate(degrees.toFloat()) }
        val rotated = Bitmap.createBitmap(bitmap, 0, 0, bitmap.width, bitmap.height, matrix, true)
        bitmap.recycle()
        val out = ByteArrayOutputStream()
        rotated.compress(Bitmap.CompressFormat.JPEG, 95, out)
        rotated.recycle()
        return out.toByteArray()
    }

    override fun applyThermalThrottle(status: ThermalStatus) {
        thermalMultiplier = when (status) {
            ThermalStatus.NONE, ThermalStatus.LIGHT -> 1.0f
            ThermalStatus.MODERATE                  -> 1.5f   // +50% cooldown
            ThermalStatus.SEVERE                    -> 3.0f   // +200% cooldown
            else                                    -> Float.MAX_VALUE // pause captures
        }
    }

    override fun release() {
        latestFullResFrame = null
    }
}

/** Thread-safe holder for the latest full-resolution frame bytes */
class FullResFrameHolder {
    private val pool = ByteArrayPool(maxPoolSize = 3)

    @Volatile private var current: ByteArray? = null
    @Volatile var width: Int = 0
    @Volatile var height: Int = 0

    fun update(nv21: ByteArray, w: Int, h: Int) {
        val buf = pool.acquire(nv21.size)
        System.arraycopy(nv21, 0, buf, 0, nv21.size)
        current?.let { pool.release(it) }
        current = buf
        width   = w
        height  = h
    }

    fun acquire(): FrameSnapshot? {
        val bytes = current ?: return null
        return FrameSnapshot(bytes.copyOf(), width, height, pool)   // safe copy
    }
}

data class FrameSnapshot(
    val nv21Bytes: ByteArray,
    val width: Int,
    val height: Int,
    private val pool: ByteArrayPool
) {
    fun recycle() = pool.release(nv21Bytes)
}

/** Simple ByteArray object pool to avoid GC pressure */
class ByteArrayPool(private val maxPoolSize: Int) {
    private val pool = ArrayDeque<ByteArray>()

    @Synchronized
    fun acquire(size: Int): ByteArray =
        pool.removeFirstOrNull()?.takeIf { it.size >= size } ?: ByteArray(size)

    @Synchronized
    fun release(bytes: ByteArray) {
        if (pool.size < maxPoolSize) pool.addLast(bytes)
    }
}
```

